[
  {
    "id": "oncology-demo",
    "name": "肿瘤分析 Agent（张三登记）",
    "version": "0.2.0",
    "domain": "oncology",
    "author": "危楚钰",
    "description": "肿瘤分析，登记练习用",
    "scenario": {
      "title": "肿瘤组学数据标准分析",
      "summary": "适用于 TCGA 等肿瘤转录组/突变数据的常规分析流程（Demo 占位）"
    },
    "capabilities": [
      "样本质控与临床信息匹配",
      "差异表达分析",
      "通路富集",
      "生存分析（Kaplan-Meier）"
    ],
    "skill_chain": [
      {
        "skill": "oncology-qc",
        "name": "肿瘤数据质控",
        "params": {
          "min_samples": 10
        }
      },
      {
        "skill": "oncology-deg",
        "name": "差异表达分析",
        "input_from": "oncology-qc.clean_matrix"
      },
      {
        "skill": "oncology-enrichment",
        "name": "通路富集",
        "input_from": "oncology-deg.deg_table"
      },
      {
        "skill": "oncology-survival",
        "name": "生存分析",
        "input_from": "oncology-qc.clinical_data"
      }
    ],
    "io": {
      "input": [
        {
          "name": "expression_matrix",
          "type": "csv",
          "description": "基因表达矩阵（行=基因，列=样本）"
        },
        {
          "name": "clinical_data",
          "type": "csv",
          "description": "样本临床信息（生存时间、分组等）"
        }
      ],
      "output": [
        {
          "name": "deg_results",
          "type": "csv",
          "description": "差异表达基因列表"
        },
        {
          "name": "enrichment_report",
          "type": "html",
          "description": "通路富集结果"
        },
        {
          "name": "survival_plot",
          "type": "png",
          "description": "生存曲线图"
        }
      ]
    },
    "evaluation": [
      {
        "name": "reproducibility",
        "threshold": 0.8,
        "description": "相同输入重复运行，核心结果一致率（老师强调的可复现性）"
      },
      {
        "name": "deg_overlap",
        "threshold": 0.9,
        "description": "与标准流程 DE 基因集重叠度"
      }
    ],
    "tags": [
      "oncology",
      "demo",
      "practice"
    ],
    "known_issues": [
      "本条目为 Phase 1 练手登记，skill id 为 mock，未接平台",
      "平台肿瘤 Agent 可复现率低，待同学试用后补充真实问题"
    ]
  },
  {
    "id": "proteomics-diff-analysis",
    "name": "蛋白质组差异分析",
    "version": "0.9.0",
    "domain": "proteomics",
    "author": "platform-team",
    "description": "搜库定量后的差异蛋白筛选与基础统计",
    "scenario": {
      "title": "两组样本差异蛋白分析",
      "summary": "适用于 label-free 定量蛋白质组数据的差异分析"
    },
    "capabilities": [
      "蛋白鉴定结果导入",
      "差异蛋白筛选",
      "火山图数据准备"
    ],
    "skill_chain": [
      {
        "skill": "proteo-import",
        "name": "蛋白鉴定结果导入"
      },
      {
        "skill": "proteo-diff",
        "name": "差异蛋白分析",
        "input_from": "proteo-import.protein_table"
      },
      {
        "skill": "proteo-volcano",
        "name": "火山图统计",
        "input_from": "proteo-diff.deg_table"
      }
    ],
    "io": {
      "input": [
        {
          "name": "protein_table",
          "type": "tsv",
          "description": "蛋白定量表"
        }
      ],
      "output": [
        {
          "name": "deg_table",
          "type": "tsv",
          "description": "差异蛋白列表"
        },
        {
          "name": "volcano_data",
          "type": "json",
          "description": "火山图数据"
        }
      ]
    },
    "tags": [
      "proteomics",
      "demo"
    ]
  },
  {
    "id": "scrna-full-analysis",
    "name": "单细胞全流程分析",
    "version": "1.0.0",
    "domain": "scrna-seq",
    "author": "platform-team",
    "description": "从质控到细胞类型注释的单细胞 RNA 测序分析 Agent",
    "scenario": {
      "title": "新样本单细胞测序数据分析",
      "summary": "适用于 10x Genomics 单细胞转录组数据的标准分析流程"
    },
    "capabilities": [
      "自动质控与过滤",
      "归一化与降维",
      "无监督聚类",
      "细胞类型注释"
    ],
    "skill_chain": [
      {
        "skill": "scrna-qc-filter",
        "name": "单细胞质控过滤",
        "params": {
          "mito_threshold": 0.2
        }
      },
      {
        "skill": "scrna-normalize",
        "name": "归一化降维",
        "input_from": "scrna-qc-filter.filtered_matrix"
      },
      {
        "skill": "scrna-cluster",
        "name": "无监督聚类",
        "input_from": "scrna-normalize.normalized_matrix"
      },
      {
        "skill": "scrna-annotate",
        "name": "细胞类型注释",
        "input_from": "scrna-cluster.cluster_labels"
      }
    ],
    "io": {
      "input": [
        {
          "name": "count_matrix",
          "type": "h5ad",
          "description": "原始或预处理后的表达矩阵"
        }
      ],
      "output": [
        {
          "name": "annotated_matrix",
          "type": "h5ad",
          "description": "带注释结果的表达矩阵"
        },
        {
          "name": "analysis_report",
          "type": "html",
          "description": "分析报告"
        }
      ]
    },
    "evaluation": [
      {
        "name": "annotation_confidence",
        "threshold": 0.7,
        "description": "细胞注释平均置信度"
      }
    ],
    "tags": [
      "scrna",
      "pipeline",
      "demo"
    ]
  }
]